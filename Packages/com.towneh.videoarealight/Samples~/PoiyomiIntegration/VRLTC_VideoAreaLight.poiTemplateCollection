#T#PoiVideoAreaLightVariables
//ifex _VideoAreaLightEnabled!=1
#ifdef POI_VIDEOAREALIGHT
    int _VideoAreaLight_UseCookie;
    int _VideoAreaLight_UsePBR;
    float _VideoAreaLight_Smoothness;
    float _VideoAreaLight_Metallic;
    float _VideoAreaLight_DiffuseMultiplier;
    float _VideoAreaLight_SpecularMultiplier;
#endif
//endex
#T#PoiVideoAreaLightFunction
//ifex _VideoAreaLightEnabled!=1
#ifdef POI_VIDEOAREALIGHT
    #include "Packages/com.towneh.videoarealight/Runtime/Shaders/RectAreaLight.hlsl"
#endif
//endex
#T#PoiVideoAreaLightFunctionCall
//ifex _VideoAreaLightEnabled!=1
#ifdef POI_VIDEOAREALIGHT
    {
        // Bent normal feeds the diffuse polygon-irradiance integral when
        // available, so occluded areas get direction-aware diffuse falloff.
        float3 _val_normal = poiMesh.normals[1];
    #ifdef POI_BENTNORMALMAP
        if (poiMesh.hasBentNormal) _val_normal = poiMesh.bentNormal;
    #endif

        // Resolve the per-fragment surface state VAL evaluates against. Two
        // modes selected by _VideoAreaLight_UsePBR:
        //
        //   1. UsePBR ON + MOCHIE_PBR compiled in — read smoothness, metallic
        //      and specularMask the Reflections & Specular module wrote to
        //      poiFragData (slider × Packed Maps × inverts × strength). The
        //      module writes the Mochie *global* masks only to mochieBRDFData,
        //      not to poiFragData, so we re-apply them here using the same
        //      customBlend pattern Poiyomi uses internally.
        //   2. UsePBR OFF, or MOCHIE_PBR not compiled in — fall back to the
        //      VAL section's own _VideoAreaLight_Smoothness / _Metallic
        //      sliders. specMask defaults to 1 (Mochie's mask system has no
        //      analogue when its module isn't present).
        float _val_smoothness = _VideoAreaLight_Smoothness;
        float _val_metallic   = _VideoAreaLight_Metallic;
        float _val_specMask   = 1;

    #ifdef MOCHIE_PBR
        if (_VideoAreaLight_UsePBR)
        {
            float _val_pbrSmoothness   = poiFragData.smoothness;
            float _val_pbrMetallic     = poiFragData.metallic;
            float _val_pbrSpecularMask = poiFragData.specularMask;

            if (_MochieMetallicGlobalMask > 0)
            {
                _val_pbrMetallic = customBlend(_val_pbrMetallic, poiMods.globalMask[_MochieMetallicGlobalMask - 1], _MochieMetallicGlobalMaskBlendType);
            }
            if (_MochieSmoothnessGlobalMask > 0)
            {
                _val_pbrSmoothness = customBlend(_val_pbrSmoothness, poiMods.globalMask[_MochieSmoothnessGlobalMask - 1], _MochieSmoothnessGlobalMaskBlendType);
            }
            if (_MochieSpecularStrengthGlobalMask > 0)
            {
                _val_pbrSpecularMask = customBlend(_val_pbrSpecularMask, poiMods.globalMask[_MochieSpecularStrengthGlobalMask - 1], _MochieSpecularStrengthGlobalMaskBlendType);
            }

            _val_smoothness = _val_pbrSmoothness;
            _val_metallic   = _val_pbrMetallic;
            _val_specMask   = _val_pbrSpecularMask;
        }
    #endif

        // Diffuse goes into finalLighting so the snapshot's baseColor
        // multiply and Poiyomi's lighting cap apply. Specular already has
        // F0 baked in, so it goes into finalLightAdd to stay independent
        // of baseColor.
        float3 _val_diffuse  = 0;
        float3 _val_specular = 0;
        VAL_EvaluateAreaLightSeparate(
            poiMesh.worldPos,
            _val_normal,
            normalize(poiCam.worldPos - poiMesh.worldPos),
            1.0 - _val_smoothness,
            poiFragData.baseColor.rgb,
            _val_metallic,
            _VideoAreaLight_UseCookie != 0,
            _val_diffuse, _val_specular);

        poiLight.finalLighting += _val_diffuse * _VideoAreaLight_DiffuseMultiplier;
        if (poiLight.lightingCapEnabled)
        {
            poiLight.finalLighting = min(poiLight.finalLighting, _LightingCap);
        }
        poiLight.finalLightAdd += _val_specular * _VideoAreaLight_SpecularMultiplier * _val_specMask;
    }
#endif
//endex
