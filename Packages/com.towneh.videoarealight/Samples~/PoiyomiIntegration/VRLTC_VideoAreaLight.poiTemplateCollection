#T#PoiVideoAreaLightFunction
//ifex _VideoAreaLightEnabled!=1
#ifdef POI_VIDEOAREALIGHT
    #include "Packages/com.towneh.videoarealight/Runtime/Shaders/RectAreaLight.hlsl"
#endif
//endex
#T#PoiVideoAreaLightFunctionCall
//ifex _VideoAreaLightEnabled!=1
#ifdef POI_VIDEOAREALIGHT
    {
        // VAL is a global emitter (one VideoAreaLightSource per scene pushes
        // _VAL_* globals via Shader.SetGlobal*). The MAIN_LIGHT_PASS gate
        // ensures we only contribute once per fragment, not per Unity light.
        float3 _val_diffuse = 0;
        float3 _val_specular = 0;

        // Bent normal feeds the diffuse polygon-irradiance integral when
        // available, matching how LTCGI handles ambient occlusion.
        float3 _val_normal = poiMesh.normals[1];
    #ifdef POI_BENTNORMALMAP
        if (poiMesh.hasBentNormal) _val_normal = poiMesh.bentNormal;
    #endif

        VAL_EvaluateAreaLight(
            poiMesh.worldPos,
            _val_normal,
            normalize(poiCam.worldPos - poiMesh.worldPos),
            1.0 - poiFragData.smoothness,
            poiFragData.baseColor.rgb,
            poiFragData.metallic,
            _VideoAreaLight_UseCookie != 0,
            _val_diffuse, _val_specular);

        // Both diffuse and specular go into finalLightAdd, NOT finalLighting.
        // The FRAGMENT_BASE_LIGHTING injection point lands AFTER Poiyomi's
        // diffuse snapshot (`finalColor = baseColor * finalLighting`), so
        // anything we add to finalLighting is dead code. finalLightAdd is
        // applied to finalColor *after* our injection, so both terms survive.
        // VAL_EvaluateAreaLight already multiplies the diffuse component by
        // baseColor internally, so we don't lose the albedo modulation.
        poiLight.finalLightAdd += _val_diffuse  * _VideoAreaLight_DiffuseMultiplier;
        poiLight.finalLightAdd += _val_specular * _VideoAreaLight_SpecularMultiplier;
    }
#endif
//endex
